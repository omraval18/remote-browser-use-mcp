BROWSER_USE_API_KEY=bu_your_browser_use_api_key_here
OPENAI_API_KEY=sk-your_openai_api_key_here
# Optional explicit override; if unset, OPENAI_API_KEY is used.
LLM_BROWSER_OPENAI_API_KEY=
BU_USE_CALCULATE_COST=true
# Optional eval/debug tracing. When false/unset, only hashes and sizes are stored.
LLM_BROWSER_RECORD_MODEL_IO=false
# Optional override for transient provider retry budget. Codex defaults to 5.
LLM_BROWSER_PROVIDER_MAX_RETRIES=
LLM_BROWSER_BROWSER_MODE=cloud
BU_NAME=rust-v14-remote-smoke

# Optional model provider keys
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# Optional Laminar telemetry.
# Agent runs read this from .env, or from the TUI's local Laminar config.
LMNR_PROJECT_API_KEY=lmnr_your_laminar_project_api_key_here
# LLM_BROWSER_LAMINAR_OTLP_ENDPOINT=https://api.lmnr.ai/v1/traces
# LLM_BROWSER_LAMINAR_CAPTURE_PAYLOADS=true

# Optional anonymous product analytics controls.
# BUT_TELEMETRY=0
# BUT_ANALYTICS_ENV=development
# BUT_POSTHOG_KEY=phc_your_dev_project_key_here
# BUT_POSTHOG_HOST=https://eu.i.posthog.com
